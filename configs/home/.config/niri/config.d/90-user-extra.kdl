// ─────────────────────────────────────────────────────────────────────────────
// 90 — Your personal overrides
// ─────────────────────────────────────────────────────────────────────────────
//
// This file is YOURS. iNiR updates will never overwrite it.
// Put any custom configuration here: extra binds, per-app window rules,
// output configuration, named workspaces, etc.
//
// Since Niri evaluates config top-to-bottom, settings here take effect
// after all other config.d files. For window-rule properties, all matching
// rules accumulate. For scalar values (like gaps), the last one wins.
// ─────────────────────────────────────────────────────────────────────────────

// ── Output config ──────────────────────────────────────────────────────────
// Primary: Samsung C32JG5x — 2560x1440 @ 144 Hz
output "DP-1" {
    mode "2560x1440@143.998"
    scale 1
    position x=0 y=0
}

// Secondary: ASUS MG28U — 2560x1440 @ 60 Hz (native 4K downscaled via mode)
output "HDMI-A-1" {
    mode "2560x1440@59.951"
    scale 1
    position x=2560 y=0
}

// Games workspace on primary monitor (DP-1, Samsung 1440p@144Hz)
workspace "G" {
    open-on-output "DP-1"
}

// Steam games via Proton — their app-id starts with steam_app_
window-rule {
    match app-id=r#"^steam_app_"#
    open-on-workspace "G"
    open-fullscreen true
}

// Overwatch
window-rule {
    match title=r#"^Overwatch"#
    open-on-workspace "G"
    open-fullscreen true
}

// If you play native Linux games, add their app-ids here:
// window-rule {
//     match app-id=r#"^(dota2|cs2|tf2)$"#
//     open-on-workspace "G"
//     open-fullscreen true
// }

// For game windows that don't match the pattern above, you can use this
// keybind to move them to the games workspace on the fly:
//   Mod+G { spawn "niri" "msg" "action" "move-window-to-workspace" "G"; spawn "niri" "msg" "action" "focus-workspace" "G"; }
